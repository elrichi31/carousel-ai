# OpenAI API Key
# Used for carousel content generation and image generation (DALL-E)
OPENAI_API_KEY=sk-your-api-key-here

# Unsplash API Keys
# Used for fetching stock images. Get them at https://unsplash.com/developers
UNSPLASH_APPLICATION_ID=your-application-id-here
UNSPLASH_ACCESS_KEY=your-access-key-here
UNSPLASH_SECRET_KEY=your-secret-key-here
